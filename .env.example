# Agent Credential Sandbox
# Copy this to .env and fill in your real credentials

# Jira (Bearer token)
JIRA_TOKEN=your-jira-personal-access-token
JIRA_URL=https://your-company.atlassian.net

# Jenkins (Basic auth)
JENKINS_USER=your-jenkins-username
JENKINS_TOKEN=your-jenkins-api-token

# Generic API (API Key)
API_KEY=your-api-key
API_URL=https://api.your-company.com

# S3-compatible storage (AWS SigV4)
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_URL=https://s3.your-company.com

# Microsoft Graph (OAuth2 Bearer)
MICROSOFT_TOKEN=your-oauth-token
GRAPH_URL=https://graph.microsoft.com