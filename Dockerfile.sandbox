FROM python:3.12-slim

WORKDIR /app

# Install runtime dependencies (only what skills need)
RUN pip install --no-cache-dir requests boto3 && \
    pip cache purge

# Create non-root user (UID 1000)
RUN useradd -m -u 1000 sandboxuser

# Switch to non-root user
USER sandboxuser

CMD ["python3", "--version"]